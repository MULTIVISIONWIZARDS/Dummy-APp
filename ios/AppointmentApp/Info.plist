<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>AppointmentApp</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- Fonts -->
    <key>UIAppFonts</key>
    <array>
        <string>MaterialCommunityIcons.ttf</string>
        <string>Feather.ttf</string>
        <string>MaterialIcons.ttf</string>
        <string>Ionicons.ttf</string>
    </array>

    <!-- New Architecture -->
    <key>RCTNewArchEnabled</key>
    <true/>

    <!-- Deep Linking: Custom URL Scheme -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.vintageappointment</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>myapp</string>
            </array>
        </dict>
    </array>

    <!-- ⚠️ IMPORTANT: App Store Review Guidelines - Permission Descriptions -->
    <!-- These descriptions must clearly explain WHY you need each permission -->
    
    <key>NSCameraUsageDescription</key>
    <string>$(PRODUCT_NAME) uses camera for video consultations with healthcare providers and for profile photos. Video calls are encrypted and not recorded.</string>

    <key>NSMicrophoneUsageDescription</key>
    <string>$(PRODUCT_NAME) uses microphone for audio during live video consultations with healthcare providers. All audio is encrypted in transit.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>$(PRODUCT_NAME) accesses photo library only when you choose to upload a profile picture. Photos are not accessed without your permission.</string>

    <!-- Agora Video SDK Required Permissions -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>$(PRODUCT_NAME) uses local network to establish peer-to-peer video connections for better quality consultations. This helps reduce latency during video calls.</string>

    <key>NSBonjourServices</key>
    <array>
        <string>_agora._udp</string>
        <string>_agora_local._tcp</string>
    </array>

    <!-- ⚠️ App Transport Security - MUST be configured properly for App Store -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Don't use NSAllowsArbitraryLoads=true for production apps -->
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        
        <!-- Allow specific Agora domains -->
        <key>NSExceptionDomains</key>
        <dict>
            <key>agora.io</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/> <!-- Keep this false, use HTTPS -->
                <key>NSExceptionRequiresForwardSecrecy</key>
                <false/>
            </dict>
            <key>edge.agora.io</key>
            <dict>
                <key>NSIncludesSubdomains</key>
                <true/>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
            </dict>
        </dict>
    </dict>

    <!-- ⚠️ Background Modes - Be specific and minimal -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string> <!-- Required to continue audio when app is backgrounded -->
        <!-- Remove 'voip' unless you're actually building a VoIP app -->
    </array>

    <!-- Required Device Capabilities -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
        <string>video-camera</string> <!-- Explicitly require video camera -->
    </array>

    <!-- Launch Screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <!-- Supported Orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
</dict>
</plist>